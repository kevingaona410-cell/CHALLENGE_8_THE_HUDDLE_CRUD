<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Huddle - Temas de Discusión</title>
    <link rel="stylesheet" href="/style/style.css">
    <script src="/js/script.js" defer></script>
</head>
<body>
    <h1>The Huddle</h1>

    <!-- Formulario para crear nuevo tema -->
    <section>
        <h2>Proponer un nuevo tema</h2>
        <form action="/" method="POST">
            <input type="text" name="title" placeholder="¿Sobre qué quieres hablar?" required style="width: 70%; padding: 8px;">
            <button type="submit" style="padding: 8px 15px;">Crear Tema</button>
        </form>
    </section>

    <hr>

    <!-- Listado de temas -->
    <section>
        {{#if topics.length}}
            {{#each topics}}
                <div class="topic-card">
                    <div class="topic-header">
                        <h3>{{this.title}} <span class="vote-badge">{{this.votes}} votos</span></h3>
                        <div>
                            <form action="/topics/{{this.id}}/vote" method="POST">
                                <button type="submit">👍 Votar</button>
                            </form>
                            <form action="/topics/{{this.id}}/delete" method="POST">
                                <button type="submit" onclick="return confirm('¿Seguro que deseas eliminar este tema?')">🗑️</button>
                            </form>
                        </div>
                    </div>

                    <div class="links-section">
                        <h4>Enlaces útiles:</h4>
                        <ul>
                            {{#each this.links}}
                                <li>
                                    <a href="{{this.url}}" target="_blank">{{this.url}}</a>
                                    <form action="/topics/{{../id}}/links/{{this.id}}/delete" method="POST" style="margin-left: 10px;">
                                        <button type="submit" style="font-size: 0.8em;">Eliminar link</button>
                                    </form>
                                </li>
                            {{/each}}
                        </ul>
                        
                        <form action="/topics/{{this.id}}/links" method="POST">
                            <input type="url" name="link" placeholder="Pegar URL aquí (http://...)" required style="width: 60%;">
                            <button type="submit">Añadir Link</button>
                        </form>
                    </div>
                </div>
            {{/each}}
        {{else}}
            <p>No hay temas propuestos todavía. ¡Sé el primero!</p>
        {{/if}}
    </section>
</body>
</html>